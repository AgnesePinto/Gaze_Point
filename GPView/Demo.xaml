<Window x:Class="Gaze_Point.GPView.Demo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gaze_Point.GPView"
        mc:Ignorable="d"
        Title="Demo" 
        Height="450" Width="800"
        WindowStyle="SingleBorderWindow" 
        WindowState="Maximized" 
        ResizeMode="CanMinimize">

    <Window.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="16"/>
            <Style.Triggers>
                
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="DeepSkyBlue"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderBrush" Value="Navy"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                </Trigger>
                
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Command: ENTER, ESC -->
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding PressEnterCommand}"/>
        <KeyBinding Key="Esc" Command="{Binding StopCommand}"/>
    </Window.InputBindings>

    <Grid>
        <!-- CONTENITORE CENTRATO -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- COLONNE (SINISTRA E DESTRA) -->
            <StackPanel Orientation="Horizontal">

                <!-- COLONNA SINISTRA -->
                <StackPanel Width="400" Margin="0,0,20,0">

                    <!-- Colore -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,20">
                        <TextBlock Text="Qual è il tuo animale preferito?" FontSize="25" Foreground="DimGray" HorizontalAlignment="Left" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtAnimale" Width="300" Height="50" HorizontalAlignment="Left">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource BaseTextBoxStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusedElementName}" Value="TxtAnimale">
                                            <Setter Property="BorderThickness" Value="4"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource GazeFocusBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>

                    <!-- Animali a casa -->
                    <TextBlock Text="Hai un animale domestico?" FontSize="25" Foreground="DimGray" Margin="0,20,0,5" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton x:Name="RbNoAnimale" Content="No" GroupName="Animale" FontSize="25" Margin="0,7,40,0">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource BaseRadioButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusedElementName}" Value="RbNoAnimale">
                                            <Setter Property="Foreground" Value="{StaticResource GazeFocusBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>

                        <RadioButton x:Name="RbSiAnimale" Content="Si" GroupName="Animale" FontSize="25" Margin="0,7,0,0">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource BaseRadioButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusedElementName}" Value="RbSiAnimale">
                                            <Setter Property="Foreground" Value="{StaticResource GazeFocusBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                    </StackPanel>

                    <!-- Animale domestico -->
                    <TextBlock Text="Quali animali hai o vorresti avere?" FontSize="25" Foreground="DimGray" Margin="0,20,0,5" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkGatto" Content="Gatto" FontSize="25" Margin="0,7,30,0">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource BaseCheckBoxStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusedElementName}" Value="ChkGatto">
                                            <Setter Property="BorderBrush" Value="{StaticResource GazeFocusBrush}"/>
                                            <Setter Property="BorderThickness" Value="3"/>
                                            <Setter Property="Background" Value="AliceBlue"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>

                        <CheckBox x:Name="ChkCane" Content="Cane" FontSize="25" Margin="0,7,30,0">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource BaseCheckBoxStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusedElementName}" Value="ChkCane">
                                            <Setter Property="BorderBrush" Value="{StaticResource GazeFocusBrush}"/>
                                            <Setter Property="BorderThickness" Value="3"/>
                                            <Setter Property="Background" Value="AliceBlue"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>

                        <CheckBox x:Name="ChkAltro" Content="Altro" FontSize="25" Margin="0,7,30,0">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource BaseCheckBoxStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusedElementName}" Value="ChkAltro">
                                            <Setter Property="BorderBrush" Value="{StaticResource GazeFocusBrush}"/>
                                            <Setter Property="BorderThickness" Value="3"/>
                                            <Setter Property="Background" Value="AliceBlue"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>
                    </StackPanel>
                </StackPanel>

                <!-- Colore -->
                <StackPanel Width="300" VerticalAlignment="Top">
                    <TextBlock Text="Colore preferito:" FontSize="25" Margin="0,0,0,5" Foreground="DimGray" HorizontalAlignment="Left"/>
                    <ComboBox x:Name="CmbColore" Width="300" Height="50" HorizontalAlignment="Left">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource BaseComboBoxStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FocusedElementName}" Value="CmbColore">
                                        <Setter Property="BorderThickness" Value="4"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource GazeFocusBrush}"/>
                                        <Setter Property="Background" Value="AliceBlue"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBoxItem Content="Rosso"/>
                        <ComboBoxItem Content="Arancione"/>
                        <ComboBoxItem Content="Giallo"/>
                        <ComboBoxItem Content="Verde"/>
                        <ComboBoxItem Content="Blu"/>
                        <ComboBoxItem Content="Viola"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Exit button -->
        <Button x:Name="BtnBack" 
                Content="ESCI" 
                Command="{Binding ReturnToMainCommand}"
                VerticalAlignment="Bottom" 
                HorizontalAlignment="Right" 
                Margin="20" 
                Focusable="False">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FocusedElementName}" Value="BtnBack">
                            <Setter Property="Background" Value="Crimson"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="DarkRed"/>
                            <Setter Property="BorderThickness" Value="5"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
