<Window x:Class="Gaze_Point.GPView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test Form" 
        Height="600" Width="800"
        WindowStyle="SingleBorderWindow" 
        WindowState="Maximized" 
        ResizeMode="CanMinimize">

    <!-- Command: ENTER, EXIT -->
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding PressEnterCommand}"/>
        <KeyBinding Key="Esc" Command="{Binding StopCommand}"/>
    </Window.InputBindings>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Scegli il form da compilare:" FontSize="28" Margin="0,0,0,10" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock FontSize="20" Margin="10" HorizontalAlignment="Center" Foreground="Gray"/>

            <!-- Start form button -->
            <Button Content="FORM TEST" 
        Command="{Binding StartCommand}" 
        x:Name="BtnTestForm" 
        Width="200" Height="90" Margin="30"
        Focusable="False">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="LightGray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FocusedElementName}" Value="BtnTestForm">
                                <Setter Property="Background" Value="LightBlue"/>
                                <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                                <Setter Property="BorderThickness" Value="6"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Start stress test button -->
            <Button Content="STRESS TEST" 
                    Command="{Binding StartStressTestCommand}" 
                    x:Name="BtnStressTestForm" 
                    Width="200" Height="90" Margin="30"
                    Focusable="False">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="LightGray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FocusedElementName}" Value="BtnStressTestForm">
                                <Setter Property="Background" Value="LightBlue"/>
                                <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                                <Setter Property="BorderThickness" Value="6"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>

</Window>

