<Window x:Class="Gaze_Point.FormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gaze_Point"
        mc:Ignorable="d"
        Title="FormWindow" Height="600" Width="800">

    <!-- Colleghiamo il tasto INVIO  -->
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding PressEnterCommand}"/>
    </Window.InputBindings>
    
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="MODULO REGISTRAZIONE" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20" 
                   HorizontalAlignment="Center" />

            <!-- NOME -->
            <TextBlock Text="Nome" FontSize="10" Margin="0,0,0,5" Foreground="DimGray" HorizontalAlignment="Left"/>
            <TextBox x:Name="TxtNome" Width="200" Height="100" FontSize="16" Margin="0,0,0,20"
                     HorizontalAlignment="Left" VerticalContentAlignment="Center"
                     Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="Gray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FocusedElementName}" Value="TxtNome">
                                <Setter Property="BorderThickness" Value="4"/>
                                <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                            </DataTrigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="LightYellow"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- COGNOME -->
            <TextBlock Text="Cognome" FontSize="10" Margin="0,0,0,5" Foreground="DimGray" HorizontalAlignment="Left"/>
            <TextBox x:Name="TxtCognome" Width="200" Height="100" FontSize="16" Margin="0,0,0,20"
                     HorizontalAlignment="Left" VerticalContentAlignment="Center"
                     Text="{Binding Cognome, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="Gray"/>
                        <Style.Triggers>
                            
                            <DataTrigger Binding="{Binding FocusedElementName}" Value="TxtCognome">
                                <Setter Property="BorderThickness" Value="4"/>
                                <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                            </DataTrigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="LightYellow"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

        </StackPanel>

        <!-- Canvas del cursore (Invariato) -->
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="20" Height="20" Fill="#4CFF0000" Stroke="Red" StrokeThickness="2" IsHitTestVisible="False">
                <Ellipse.RenderTransform>
                    <TranslateTransform X="{Binding MyGazeCursor.X}" Y="{Binding MyGazeCursor.Y}" />
                </Ellipse.RenderTransform>
                <Ellipse.Margin>
                    <Thickness Left="-10" Top="-10" Right="0" Bottom="0"/>
                </Ellipse.Margin>
            </Ellipse>
        </Canvas>
    </Grid>
</Window>
