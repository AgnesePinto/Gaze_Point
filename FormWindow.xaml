<Window x:Class="Gaze_Point.FormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gaze_Point"
        mc:Ignorable="d"
        Title="FormWindow" 
        Height="650" Width="800"
        WindowStyle="SingleBorderWindow" 
        WindowState="Maximized" 
        ResizeMode="CanMinimize">

    <!-- Comandi associati ai tasti: INVIO, ESC -->
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding PressEnterCommand}"/>
        <KeyBinding Key="Esc" Command="{Binding StopCommand}"/>
    </Window.InputBindings>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="MODULO REGISTRAZIONE" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20" 
                   HorizontalAlignment="Center" />

            <!-- NOME -->
            <TextBlock Text="Nome" FontSize="15" Margin="0,0,0,5" Foreground="DimGray" HorizontalAlignment="Left"/>
            <TextBox x:Name="TxtNome" Width="250" Height="40" FontSize="16" Margin="0,0,0,15"
                     HorizontalAlignment="Left" VerticalContentAlignment="Center"
                     Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="Gray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FocusedElementName}" Value="TxtNome">
                                <Setter Property="BorderThickness" Value="4"/>
                                <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                            </DataTrigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="LightYellow"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- COGNOME -->
            <TextBlock Text="Cognome" FontSize="15" Margin="0,0,0,5" Foreground="DimGray" HorizontalAlignment="Left"/>
            <TextBox x:Name="TxtCognome" Width="250" Height="40" FontSize="16" Margin="0,0,0,20"
                     HorizontalAlignment="Left" VerticalContentAlignment="Center"
                     Text="{Binding Cognome, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="Gray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FocusedElementName}" Value="TxtCognome">
                                <Setter Property="BorderThickness" Value="4"/>
                                <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                            </DataTrigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="LightYellow"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- PANEL PROFESSIONE -->
            <TextBlock Text="Professione" FontSize="15" Foreground="DimGray" Margin="0,0,0,5" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <CheckBox x:Name="ChkLavoratore" Content="Lavoratore" FocusVisualStyle="{x:Null}" FontSize="15" Margin="0,0,15,0">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusedElementName}" Value="ChkLavoratore">
                                    <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                                    <Setter Property="BorderThickness" Value="3"/>
                                    <Setter Property="Background" Value="AliceBlue"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <CheckBox x:Name="ChkStudente" Content="Studente" FocusVisualStyle="{x:Null}" FontSize="15" Margin="0,0,15,0">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusedElementName}" Value="ChkStudente">
                                    <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                                    <Setter Property="BorderThickness" Value="3"/>
                                    <Setter Property="Background" Value="AliceBlue"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <CheckBox x:Name="ChkEntrambi" Content="Entrambi" FocusVisualStyle="{x:Null}" FontSize="15">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusedElementName}" Value="ChkEntrambi">
                                    <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                                    <Setter Property="BorderThickness" Value="3"/>
                                    <Setter Property="Background" Value="AliceBlue"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>
            </StackPanel>

            <!-- PANEL TRASPORTO -->
            <TextBlock Text="Come vieni in università:" FontSize="15" Foreground="DimGray" Margin="0,0,0,5" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <RadioButton x:Name="RbPiedi" Content="A piedi" FocusVisualStyle="{x:Null}" FontSize="15" Margin="0,0,15,0" GroupName="Trasporto">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusedElementName}" Value="RbPiedi">
                                    <Setter Property="Foreground" Value="DeepSkyBlue"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>

                <RadioButton x:Name="RbBici" Content="Bicicletta" FocusVisualStyle="{x:Null}" FontSize="15" Margin="0,0,15,0" GroupName="Trasporto">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusedElementName}" Value="RbBici">
                                    <Setter Property="Foreground" Value="DeepSkyBlue"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>

                <RadioButton x:Name="RbMezzi" Content="Mezzi Pubblici" FocusVisualStyle="{x:Null}" FontSize="15" Margin="0,0,15,0" GroupName="Trasporto">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusedElementName}" Value="RbMezzi">
                                    <Setter Property="Foreground" Value="DeepSkyBlue"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>

                <RadioButton x:Name="RbAuto" Content="Automobile" FocusVisualStyle="{x:Null}" FontSize="15" GroupName="Trasporto">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusedElementName}" Value="RbAuto">
                                    <Setter Property="Foreground" Value="DeepSkyBlue"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
            </StackPanel>
        </StackPanel>

        <!-- GAZE CURSOR -->
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="20" Height="20" Fill="#4CFF0000" Stroke="Red" StrokeThickness="2">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <!-- Di base lo teniamo nascosto -->
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <!-- Lo mostriamo solo se IsCursorVisible è True -->
                            <DataTrigger Binding="{Binding IsCursorVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>

                <Ellipse.RenderTransform>
                    <TranslateTransform X="{Binding MyGazeCursor.X}" Y="{Binding MyGazeCursor.Y}" />
                </Ellipse.RenderTransform>

                <Ellipse.Margin>
                    <Thickness Left="-10" Top="-10" Right="0" Bottom="0"/>
                </Ellipse.Margin>
            </Ellipse>
        </Canvas>
    </Grid>
</Window>

    
