<Window x:Class="Gaze_Point.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test Form" Height="600" Width="800">

    <!-- Colleghiamo il tasto INVIO. Nota: usiamo FocusManager per sicurezza -->
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding PressEnterCommand}"/>
    </Window.InputBindings>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Vuoi procedere con l'operazione?" FontSize="28" Margin="0,0,0,10" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="{Binding Status}" FontSize="20" Margin="10" HorizontalAlignment="Center" Foreground="Gray"/>

            <!-- BOTTONE AVVIA -->
            <Button Content="AVVIA TRACKING" 
                    Command="{Binding StartCommand}" 
                    x:Name="BtnStart" 
                    Width="400" Height="150" Margin="30"
                    Focusable="False">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="LightGray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FocusedElementName}" Value="BtnStart">
                                <Setter Property="Background" Value="LightBlue"/>
                                <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                                <Setter Property="BorderThickness" Value="6"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button x:Name="BtnStop" 
                    Content="FERMA TRACKING" 
                    Command="{Binding StopCommand}" 
                    Width="400" Height="150" Margin="30"
                    Focusable="False">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FocusedElementName}" Value="BtnStop">
                                <Setter Property="Foreground" Value="LimeGreen"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="BorderBrush" Value="LimeGreen"/>
                                <Setter Property="BorderThickness" Value="10"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
