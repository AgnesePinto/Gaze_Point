<Window x:Class="Gaze_Point.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test Form" Height="600" Width="800">

    <!-- Colleghiamo il tasto INVIO della tastiera al comando nel ViewModel -->
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding PressEnterCommand}"/>
    </Window.InputBindings>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- SEZIONE DOMANDA INTERATTIVA (Nuova) -->
            <TextBlock Text="Vuoi procedere con l'operazione?" FontSize="24" Margin="0,0,0,10" HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                <!-- CheckBox SI -->
                <CheckBox Content="SI" x:Name="CbSi" FontSize="20" Margin="20" Padding="10,0,10,0">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Style.Triggers>
                                <!-- Se il nome di questo elemento corrisponde a quello fissato, diventa azzurro -->
                                <DataTrigger Binding="{Binding FocusedElementName}" Value="CbSi">
                                    <Setter Property="Background" Value="LightBlue"/>
                                    <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                                    <Setter Property="BorderThickness" Value="3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <!-- CheckBox NO -->
                <CheckBox Content="NO" x:Name="CbNo" FontSize="20" Margin="20" Padding="10,0,10,0">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusedElementName}" Value="CbNo">
                                    <Setter Property="Background" Value="LightBlue"/>
                                    <Setter Property="BorderBrush" Value="DeepSkyBlue"/>
                                    <Setter Property="BorderThickness" Value="3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>
            </StackPanel>

            <!-- SEZIONE CONTROLLO TRACKING  -->
            <TextBlock Text="{Binding Status}" FontSize="20" Margin="10" HorizontalAlignment="Center"/>
            <Button Content="AVVIA TRACKING" Command="{Binding StartCommand}" Width="200" Height="80" Margin="10"/>
            <Button Content="FERMA TRACKING" Command="{Binding StopCommand}" Width="200" Height="80" Margin="10"/>

        </StackPanel>
    </Grid>
</Window>


