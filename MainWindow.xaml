<Window x:Class="Gaze_Point.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test Form" Height="600" Width="800">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Status}" FontSize="20" Margin="10"/>
            <Button Content="AVVIA TRACKING" Command="{Binding StartCommand}" Width="150" Height="50" Margin="5"/>
            <Button Content="FERMA TRACKING" Command="{Binding StopCommand}" Width="150" Height="50" Margin="5"/>
        </StackPanel>


        <Canvas IsHitTestVisible="False">
            <Ellipse Name="GazeCursor" Width="20" Height="20" Fill="Red" Opacity="0.5"/>
        </Canvas>
    </Grid>
</Window>

